# Option A (recommended for passwords with special chars): plain-text password, encoded in code
MONGO_USERNAME=your_atlas_username
MONGO_PASSWORD=your_plain_password
MONGO_HOST=cluster0.xxxxx.mongodb.net
MONGO_DB=not_paytm

# Option B: full connection string (password must be URL-encoded manually)
# MONGO_URL=mongodb+srv://user:encodedPassword@cluster0.xxxxx.mongodb.net/not_paytm

JWT_SECRET=change-me-to-a-long-random-string-min-16-chars
PORT=3000
NODE_ENV=development
FRONTEND_URL=http://localhost:5173

# Email (Resend) - optional in dev (links logged to console)
RESEND_API_KEY=
EMAIL_FROM=onboarding@resend.dev

# Token TTLs
ACCESS_TOKEN_TTL=15m
REFRESH_TOKEN_TTL=7d
REFRESH_TOKEN_TTL_REMEMBER=30d
